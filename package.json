{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate:social-images": "node scripts/generate-social-images.mjs",
    "sync:social-metadata": "node scripts/sync-social-metadata.mjs",
    "prebuild": "npm run generate:social-images && npm run sync:social-metadata",
    "build": "vite build",
    "postbuild": "node scripts/i18n/finalize-dist.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "echo \"No tests configured yet.\"",
    "deploy": "npm run build && firebase deploy"
  },
  "devDependencies": {
    "puppeteer": "^25.1.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "firebase": "^12.12.1"
  }
}
